# Copy this to .env for local development
# NEVER commit .env — it is in .gitignore

# Backend
ENVIRONMENT=development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ceep
DB_USER=ceep_admin
DB_PASSWORD=changeme_local

# Leave empty locally; Lambda sets this to point to Secrets Manager
DB_SECRET_ARN=

# S3 (use LocalStack or real bucket names)
PUBLIC_BUCKET=ceep-public-docs-local
PRIVATE_BUCKET=ceep-private-uploads-local

# AWS
AWS_REGION_NAME=us-east-1

# Bedrock model IDs (these are the real Bedrock IDs)
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# SQS (leave empty to skip queue in local dev)
INGEST_QUEUE_URL=

# Frontend (set this to the API Gateway URL)
VITE_API_URL=http://localhost:8000
