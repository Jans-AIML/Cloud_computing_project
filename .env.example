# Copy this to backend/.env for local development
# NEVER commit .env — it is in .gitignore
#
# Switch between local (free) and production (AWS) with two variables:
#   LLM_PROVIDER=local   → Ollama on localhost:11434
#   LLM_PROVIDER=bedrock → AWS Bedrock (needs AWS credentials)

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "local" = Ollama (start with: docker compose up -d)
# "bedrock" = AWS Bedrock (production only, needs AWS credentials)
LLM_PROVIDER=local

# ── Ollama (used when LLM_PROVIDER=local) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ── Storage (used when LLM_PROVIDER=local) ─────────────────────────────────────
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./local_data

# ── Database (matches docker-compose.yml) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ceep
DB_USER=ceep_admin
DB_PASSWORD=changeme_local
DB_SECRET_ARN=

# ── S3 bucket names (not used locally, but required by config) ─────────────────
PUBLIC_BUCKET=ceep-public-docs-local
PRIVATE_BUCKET=ceep-private-uploads-local

# ── AWS (only needed when LLM_PROVIDER=bedrock) ────────────────────────────────
AWS_REGION_NAME=us-east-1
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# ── SQS (not used locally) ─────────────────────────────────────────────────────
INGEST_QUEUE_URL=

# ── Frontend ───────────────────────────────────────────────────────────────────
# For local dev Vite proxies /api → localhost:8000 automatically (see vite.config.ts)
VITE_API_URL=http://localhost:8000
