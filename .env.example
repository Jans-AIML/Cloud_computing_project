# Copy this to backend/.env for local development.
# NEVER commit .env — it is in .gitignore.
#
# LLM_PROVIDER controls which backend is used for chat + embeddings:
#   LLM_PROVIDER=groq    → Groq API (chat) + fastembed (embeddings) — recommended for local dev
#   LLM_PROVIDER=local   → Ollama on localhost:11434 (fully offline, slower)
#   LLM_PROVIDER=bedrock → AWS Bedrock (not actively used; requires quota)

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=groq

# ── Groq (used when LLM_PROVIDER=groq) ────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Embeddings: fastembed runs locally (no API key needed)
# Model is downloaded automatically on first run to LOCAL_STORAGE_PATH/fastembed_cache
EMBED_DIM=384

# ── Ollama (used when LLM_PROVIDER=local) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Storage ────────────────────────────────────────────────────────────────────
# For local dev, files are stored in LOCAL_STORAGE_PATH instead of S3.
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./local_data

# ── Database (matches docker-compose.yml) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ceep
DB_USER=ceep_admin
DB_PASSWORD=changeme_local
DB_SECRET_ARN=

# ── S3 bucket names (required by config even when USE_LOCAL_STORAGE=true) ──────
PUBLIC_BUCKET=ceep-public-docs-local
PRIVATE_BUCKET=ceep-private-uploads-local

# ── AWS region (only needed when deploying to AWS or LLM_PROVIDER=bedrock) ─────
AWS_REGION_NAME=us-east-1

# ── Frontend ───────────────────────────────────────────────────────────────────
# Vite proxies /api → localhost:8001 in dev mode (see vite.config.ts).
# No change needed here for local dev.
VITE_API_URL=http://localhost:8001
